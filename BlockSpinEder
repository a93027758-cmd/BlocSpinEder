Conexiones.ESPInv = RunService.RenderStepped:Connect(function()
    if not ESPInventarioActivo then return end

    for _, Objetivo in ipairs(Players:GetPlayers()) do
        if Objetivo == LocalPlayer then continue end
        local Char = Objetivo.Character
        if not Char then continue end
        local Hum = Char:FindFirstChildOfClass("Humanoid")
        local RootP = Char:FindFirstChild("HumanoidRootPart")
        if not Hum or not RootP or Hum.Health <= 0 then
            if DatosESP[Objetivo.UserId] and DatosESP[Objetivo.UserId].Inventario then
                DatosESP[Objetivo.UserId].Inventario.Parent:Destroy()
                DatosESP[Objetivo.UserId].Inventario = nil
            end
            continue
        end

        -- Obtener objetos
        local Lista = {}
        if Objetivo.Backpack then
            for _, Item in ipairs(Objetivo.Backpack:GetChildren()) do
                if Item:IsA("Tool") then
                    table.insert(Lista, "• " .. Item.Name)
                end
            end
        end
        local Equipado = Hum:FindFirstChildOfClass("Tool")
        if Equipado then
            table.insert(Lista, "✅ EQUIPADO: " .. Equipado.Name)
        end

        local TextoInv = #Lista > 0 and table.concat(Lista, "\n") or "Sin objetos"

        if not DatosESP[Objetivo.UserId] then DatosESP[Objetivo.UserId] = {} end
        if not DatosESP[Objetivo.UserId].Inventario then
            local GuiInv = Instance.new("BillboardGui")
            GuiInv.Adornee = RootP
            GuiInv.Size = UDim2.new(0, 260, 0, 220)
            GuiInv.AlwaysOnTop = true
            GuiInv.Parent = ScreenGui

            local EtiquetaInv = Instance.new("TextLabel")
            EtiquetaInv.Size = UDim2.new(1, 0, 1, 0)
            EtiquetaInv.BackgroundTransparency = 1
            EtiquetaInv.TextColor3 = Color3.fromRGB(120, 255, 120)
            EtiquetaInv.TextStrokeTransparency = 0.4
            EtiquetaInv.TextStrokeColor3 = Color3.new(0,0,0)
            EtiquetaInv.TextSize = 12
            EtiquetaInv.Font = Enum.Font.GothamSemibold
            EtiquetaInv.TextWrapped = true
            EtiquetaInv.TextAlign = Enum.TextAlign.Center
            EtiquetaInv.Parent = GuiInv

            DatosESP[Objetivo.UserId].Inventario = EtiquetaInv
        end

        DatosESP[Objetivo.UserId].Inventario.Text = "🎒 INVENTARIO:\n" .. TextoInv
    end
end)

