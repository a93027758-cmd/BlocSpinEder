-- Función para actualizar la lista de ignorados
local function UpdateIgnoredList(texto)
    IgnoredUsers = {}
    for usuario in texto:gmatch("[^,]+") do
        usuario = usuario:gsub("^%s*(.-)%s*$", "%1"):lower()
        if usuario ~= "" then
            IgnoredUsers[usuario] = true
        end
    end
end

IgnoreInput.FocusLost:Connect(function()
    UpdateIgnoredList(IgnoreInput.Text)
    Notify("Lista actualizada", #IgnoreInput.Text > 0 and "Se ignorarán los usuarios indicados" or "Sin usuarios a ignorar")
end)

-- Acción del botón borrar
ClearIgnoreBtn.MouseButton1Click:Connect(function()
    IgnoreInput.Text = ""
    UpdateIgnoredList("")
    Notify("Lista limpiada", "Todos los usuarios fueron eliminados de la lista")
end)

-- Función auxiliar: ¿El usuario está en la lista de ignorados?
local function IsIgnored(playerName)
    return IgnoredUsers[playerName:lower()] == true
end

