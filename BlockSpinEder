-- Lógica Aimbot CORREGIDA
Conexiones.Aimbot = RunService.RenderStepped:Connect(function()
    if not AimbotActivo or not RootPart then return end
    local MejorObjetivo, MejorDist = nil, math.huge

    for _, Objetivo in ipairs(Players:GetPlayers()) do
        if Objetivo == LocalPlayer then continue end
        local Char = Objetivo.Character
        if not Char then continue end
        local Hum = Char:FindFirstChildOfClass("Humanoid")
        local RootP = Char:FindFirstChild("HumanoidRootPart")
        if not Hum or not RootP or Hum.Health <= 0 then continue end

        local Parte = ApuntarCabeza and Char:FindFirstChild("Head") or RootP
        if not Parte then continue end

        -- Verificación de visión exacta
        local Visible = true
        if SoloConVision then
            local Rayo = Ray.new(Camera.CFrame.Position, (Parte.Position - Camera.CFrame.Position).Unit * 1000)
            local Ignorar = {LocalPlayer.Character, Char}
            local Golpeado = Workspace:FindPartOnRayWithIgnoreList(Rayo, Ignorar)
            Visible = not Golpeado or Golpeado:IsDescendantOf(Char)
        end
        if not Visible then continue end

        local EnPantalla, EnVista = Camera:WorldToViewportPoint(Parte.Position)
        if EnVista then
            local Centro = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
            local Distancia = (Vector2.new(EnPantalla.X, EnPantalla.Y) - Centro).Magnitude
            if Distancia < FOV and Distancia < MejorDist then
                MejorDist = Distancia
                MejorObjetivo = Parte
            end
        end
    end

    if MejorObjetivo then
        Camera.CFrame = CFrame.new(Camera.CFrame.Position, MejorObjetivo.Position)
    end
end)

