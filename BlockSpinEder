Conexiones.ESPJug = RunService.RenderStepped:Connect(function()
    if not ESPJugadoresActivo then return end
    local Activos = {}

    for _, Objetivo in ipairs(Players:GetPlayers()) do
        if Objetivo == LocalPlayer then continue end
        local Char = Objetivo.Character
        if not Char then continue end
        local Hum = Char:FindFirstChildOfClass("Humanoid")
        local RootP = Char:FindFirstChild("HumanoidRootPart")
        if not Hum or not RootP or Hum.Health <= 0 then
            if DatosESP[Objetivo.UserId] then
                DatosESP[Objetivo.UserId].Contorno:Destroy()
                DatosESP[Objetivo.UserId].Texto.Parent:Destroy()
                DatosESP[Objetivo.UserId] = nil
            end
            continue
        end

        Activos[Objetivo.UserId] = true
        local Distancia = math.floor((RootPart.Position - RootP.Position).Magnitude)

        if not DatosESP[Objetivo.UserId] then
            -- Contorno que se ve por paredes
            local Contorno = Instance.new("Highlight")
            Contorno.Adornee = Char
            Contorno.FillTransparency = 1
            Contorno.OutlineTransparency = 0
            Contorno.OutlineColor = Color3.fromRGB(255, 0, 0) -- Rojo brillante
            Contorno.OutlineThickness = 2
            Contorno.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            Contorno.Parent = ScreenGui

            -- Texto ordenado y en rojo
            local GuiTexto = Instance.new("BillboardGui")
            GuiTexto.Adornee = Char:FindFirstChild("Head") or RootP
            GuiTexto.Size = UDim2.new(0, 230, 0, 80)
            GuiTexto.AlwaysOnTop = true
            GuiTexto.Parent = ScreenGui

            local Etiqueta = Instance.new("TextLabel")
            Etiqueta.Size = UDim2.new(1, 0, 1, 0)
            Etiqueta.BackgroundTransparency = 1
            Etiqueta.TextColor3 = Color3.fromRGB(255, 30, 30) -- Rojo que resalta
            Etiqueta.TextStrokeTransparency = 0.3 -- Borde negro para que se lea mejor
            Etiqueta.TextStrokeColor3 = Color3.new(0,0,0)
            Etiqueta.TextSize = 15
            Etiqueta.Font = Enum.Font.GothamBold
            Etiqueta.TextWrapped = true
            Etiqueta.TextAlign = Enum.TextAlign.Center
            Etiqueta.Parent = GuiTexto

            DatosESP[Objetivo.UserId] = {
                Contorno = Contorno,
                Texto = Etiqueta
            }
        end

        -- Texto ordenado
        DatosESP[Objetivo.UserId].Texto.Text = string.format([[
👤 %s
❤️ Vida: %d / 100
📏 Distancia: %d m
        ]], Objetivo.Name, math.floor(Hum.Health), Distancia)
    end

    -- Limpiar jugadores que ya no están
    for Id in pairs(DatosESP) do
        if not Activos[Id] then
            if DatosESP[Id].Contorno then DatosESP[Id].Contorno:Destroy() end
            if DatosESP[Id].Texto then DatosESP[Id].Texto.Parent:Destroy() end
            DatosESP[Id] = nil
        end
    end
end)

